{
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "SmartPriceTracker",
    "Audience": "SmartPriceTrackerUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "SecureSocketOptions": "StartTls",
    "TimeoutMs": 30000,
    "Username": "",
    "Password": "",
    "From": "",
    "FromName": "Smart Price Tracker"
  },
  "Auth": {
    "EmailVerificationExpiryHours": 24,
    "PasswordResetExpiryHours": 1
  },
  "Frontend": {
    "BaseUrl": ""
  },
  "InternalApi": {
    "Key": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Hangfire": {
    "DashboardPath": "/hangfire",
    "DashboardApiKey": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
