# Copy to docker/.env and fill in values. Never commit docker/.env.

POSTGRES_DB=price_tracker_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

JWT_SECRET=change-me-to-at-least-32-characters-long
INTERNAL_API_KEY=change-me-min-16-chars
HANGFIRE_DASHBOARD_API_KEY=change-me-min-16-chars

ALLOWED_HOSTS=localhost;127.0.0.1
FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Gmail SMTP (use App Password, not Google account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your@gmail.com

# Same-origin API via nginx in the frontend container (leave empty to use relative /v1 paths)
VITE_API_URL=
